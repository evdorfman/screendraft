<script>
// Storage shim: the app was built for Claude's artifact sandbox, which
// provides a window.storage key-value API automatically. That doesn't
// exist on a plain static site, so this replaces it with an equivalent
// backed by the browser's own localStorage -- same interface, same
// behavior, data now lives on this device instead.
window.storage = {
  async get(key) {
    const raw = localStorage.getItem('reelink:' + key);
    if (raw === null) throw new Error('Key not found: ' + key);
    return { key, value: raw };
  },
  async set(key, value) {
    localStorage.setItem('reelink:' + key, value);
    return { key, value };
  },
  async delete(key) {
    localStorage.removeItem('reelink:' + key);
    return { key, deleted: true };
  },
  async list(prefix) {
    const p = 'reelink:' + (prefix || '');
    const keys = [];
    for (let i = 0; i < localStorage.length; i++) {
      const k = localStorage.key(i);
      if (k && k.startsWith(p)) keys.push(k.slice('reelink:'.length));
    }
    return { keys, prefix };
  },
};
