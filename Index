        .rw-brand-name{ font-weight:700; letter-spacing:.02em; font-size:15px; }
        .rw-brand-sub{ color:var(--muted); font-size:11px; margin-top:2px; letter-spacing:.08em; text-transform:uppercase; }
        .rw-newbtn{ margin:14px 18px 8px; background:var(--amber); color:#1a1305; border:none; border-radius:8px; padding:10px 12px; font-weight:600; font-size:13px; }
        .rw-newbtn:hover{ background:var(--amber-soft); }
        .rw-importbtn{ margin:0 18px 14px; background:var(--panel2); color:var(--text); border:1px solid var(--border); border-radius:8px; padding:9px 12px; font-weight:600; font-size:13px; }
        .rw-importbtn:hover{ border-color:var(--teal); color:var(--teal); }
        .rw-importbtn:disabled{ opacity:.6; cursor:wait; }
        .rw-importerror{ margin:0 18px 12px; font-size:11px; color:#e08a8a; line-height:1.4; }
        .rw-importbanner{ display:flex; align-items:center; justify-content:space-between; gap:12px; background:rgba(62,124,140,.15); border:1px solid rgba(62,124,140,.4); border-radius:10px; padding:10px 14px; margin-bottom:14px; font-family:'IBM Plex Sans',sans-serif; font-size:12.5px; color:var(--text); max-width:8.5in; width:100%; }
        .rw-importbanner button{ background:var(--teal); color:#0e2126; border:none; border-radius:6px; padding:6px 10px; font-size:11.5px; font-weight:600; white-space:nowrap; }
        .rw-importbanner .rw-dismiss{ background:none; color:var(--muted); padding:4px 6px; }
        .sp-flagged{ background:rgba(201,138,62,.14); box-shadow:inset 3px 0 0 var(--amber); border-radius:2px; }
        .sp-reading{ background:rgba(62,124,140,.22); box-shadow:inset 3px 0 0 var(--teal); border-radius:2px; }
        .rw-projects{ flex:1; overflow-y:auto; padding:6px 10px; }
        .rw-project{ padding:10px 10px; border-radius:8px; cursor:pointer; margin-bottom:2px; display:flex; justify-content:space-between; align-items:center; gap:6px; }
        .rw-project:hover{ background:var(--panel2); }
        .rw-project.active{ background:var(--panel2); box-shadow:inset 2px 0 0 var(--amber); }
        .rw-project-title{ font-size:13px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
        .rw-project-del{ opacity:0; background:none; border:none; color:var(--muted); font-size:14px; }
        .rw-project:hover .rw-project-del{ opacity:1; }
        .rw-sidebar-footer{ padding:14px 18px; border-top:1px solid var(--border); font-size:11px; color:var(--muted); }

        /* ---------- Right panel: scenes / versions ---------- */
        .rw-navpanel{ width:290px; flex-shrink:0; background:var(--panel); border-left:1px solid var(--border); height:100vh; position:sticky; top:0; display:flex; flex-direction:column; z-index:35; }
        .rw-navtabs{ display:flex; gap:2px; background:var(--panel2); padding:3px; border-radius:8px; margin:14px; }
        .rw-navtab{ flex:1; background:none; border:none; color:var(--muted); font-size:12px; padding:7px 8px; border-radius:6px; }
        .rw-navtab.active{ background:var(--amber); color:#1a1305; font-weight:600; }
        .rw-navlist{ flex:1; overflow-y:auto; padding:0 14px 14px; }
        .rw-scene-item{ padding:10px 10px; border-radius:8px; cursor:pointer; margin-bottom:4px; border:1px solid transparent; }
        .rw-scene-item:hover{ background:var(--panel2); border-color:var(--border); }
        .rw-scene-num{ color:var(--amber); font-size:10px; font-weight:700; letter-spacing:.05em; }
        .rw-scene-heading{ font-family:'Courier Prime',monospace; font-size:12px; margin-top:2px; line-height:1.3; }
        .rw-scene-page{ color:var(--muted); font-size:10px; margin-top:3px; }
        .rw-empty{ color:var(--muted); font-size:12px; padding:20px 6px; text-align:center; }
        .rw-savever{ margin:0 14px 12px; background:var(--teal); color:#0e2126; border:none; border-radius:8px; padding:9px 10px; font-weight:600; font-size:12px; }
        .rw-version-item{ padding:10px; border-radius:8px; margin-bottom:6px; background:var(--panel2); border:1px solid var(--border); }
        .rw-version-label{ font-size:12.5px; font-weight:600; }
        .rw-version-date{ color:var(--muted); font-size:10px; margin:2px 0 8px; }
        .rw-version-actions{ display:flex; gap:6px; }
        .rw-version-actions button{ flex:1; background:var(--ink); border:1px solid var(--border); color:var(--text); border-radius:6px; padding:5px 6px; font-size:11px; }
        .rw-version-actions button:hover{ border-color:var(--amber); color:var(--amber-soft); }
        .rw-version-actions button.danger:hover{ border-color:#c95d5d; color:#e08a8a; }

        /* ---------- Topbar ---------- */
        .rw-main{ flex:1; min-width:0; display:flex; flex-direction:column; height:100vh; overflow:hidden; }
        .rw-topbar{ display:flex; align-items:center; gap:8px; padding:10px 16px; border-bottom:1px solid var(--border); background:var(--panel); flex-wrap:wrap; }
        .rw-hamb{ display:none; background:none; border:1px solid var(--border); color:var(--text); border-radius:6px; width:34px; height:34px; flex-shrink:0; }
        .rw-title-field{ background:transparent; border:none; color:var(--text); font-size:15px; font-weight:600; outline:none; flex:1; min-width:80px; }
        .rw-tabs{ display:flex; gap:2px; background:var(--panel2); padding:3px; border-radius:8px; flex-shrink:0; }
        .rw-tab{ background:none; border:none; color:var(--muted); font-size:12px; padding:6px 12px; border-radius:6px; }
        .rw-tab.active{ background:var(--amber); color:#1a1305; font-weight:600; }
        .rw-iconbtn{ background:var(--panel2); border:1px solid var(--border); color:var(--text); border-radius:8px; padding:8px 12px; font-size:12px; font-weight:600; white-space:nowrap; }
        .rw-iconbtn:hover{ border-color:var(--amber); color:var(--amber-soft); }
        .rw-iconbtn.on{ border-color:var(--amber); color:var(--amber-soft); }
        .rw-export{ background:var(--teal); color:#0e2126; border:none; border-radius:8px; padding:8px 14px; font-weight:600; font-size:13px; white-space:nowrap; }
        .rw-export:hover{ filter:brightness(1.1); }

        /* ---------- Page canvas ---------- */
        .rw-canvas{ flex:1; overflow-y:auto; padding:36px 20px 24px; display:flex; flex-direction:column; align-items:center; gap:28px; }
        .rw-page{ width:100%; max-width:8.5in; min-height:11in; background:var(--paper); color:#111; box-shadow:0 10px 40px rgba(0,0,0,.45); padding:1in 1in 1in 1.5in; font-family:'Courier Prime',monospace; font-size:12pt; line-height:13pt; position:relative; }
        .rw-pagebadge{ position:absolute; top:.45in; right:1in; font-size:10pt; color:#8a8474; }

        .sp-block{ outline:none; white-space:pre-wrap; word-wrap:break-word; min-height:1em; caret-color:#111; }
        .sp-block:empty::before{ content: attr(data-placeholder); color:#b9b3a4; }
        .sp-scene_heading{ text-transform:uppercase; font-weight:700; margin-top:13pt; }
        .sp-action{ margin-top:13pt; }
        .sp-character{ text-transform:uppercase; margin-top:13pt; margin-left:2.2in; }
        .sp-parenthetical{ margin-top:0; margin-left:1.6in; max-width:2in; }
        .sp-dialogue{ margin-top:0; margin-left:1in; max-width:3.8in; }
        .sp-transition{ text-transform:uppercase; margin-top:13pt; text-align:right; }
        .sp-shot{ text-transform:uppercase; font-weight:700; margin-top:13pt; }

        .rw-type-badge{ display:inline-block; font-family:'IBM Plex Sans',sans-serif; font-size:9px; letter-spacing:.06em; color:var(--amber); background:rgba(201,138,62,.12); border:1px solid rgba(201,138,62,.35); border-radius:4px; padding:1px 5px; margin-bottom:3px; }

        .rw-chiprow{ display:flex; gap:6px; flex-wrap:wrap; margin:0 0 10px; font-family:'IBM Plex Sans',sans-serif; max-width:8.5in; width:100%; }
        .rw-chip{ background:var(--panel2); border:1px solid var(--border); color:var(--text); font-size:11px; padding:4px 9px; border-radius:20px; }
        .rw-chip:hover{ border-color:var(--amber); color:var(--amber-soft); }

        /* ---------- Notes / Cast / Board (project aux docs) ---------- */
        .rw-notes-wrap{ width:100%; max-width:8.5in; }
        .rw-notes{ width:100%; min-height:70vh; background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:22px; color:var(--text); font-family:'IBM Plex Sans',sans-serif; font-size:14.5px; line-height:1.6; outline:none; resize:vertical; }
        .rw-notes:focus{ border-color:var(--amber); }

        .rw-castwrap{ width:100%; max-width:8.5in; }
        .rw-addbtn{ background:var(--amber); color:#1a1305; border:none; border-radius:8px; padding:9px 14px; font-weight:600; font-size:13px; }
        .rw-addbtn:hover{ background:var(--amber-soft); }
        .rw-empty-lg{ color:var(--muted); font-size:13px; line-height:1.6; padding:30px 10px; text-align:center; background:var(--panel); border:1px dashed var(--border); border-radius:12px; }
        .rw-empty-sm{ color:var(--muted); font-size:12px; text-align:center; padding:18px 8px; border:1px dashed var(--border); border-radius:10px; }

        .rw-charcard{ background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:16px; margin-bottom:12px; }
        .rw-charname{ width:100%; background:transparent; border:none; border-bottom:1px solid var(--border); color:var(--amber-soft); font-weight:700; font-size:14px; letter-spacing:.03em; padding:4px 0 8px; outline:none; font-family:'IBM Plex Sans',sans-serif; }
        .rw-chardesc{ width:100%; min-height:70px; background:transparent; border:none; color:var(--text); font-family:'IBM Plex Sans',sans-serif; font-size:13.5px; line-height:1.5; margin-top:10px; outline:none; resize:vertical; }
        .rw-voiceselect{ width:100%; margin-top:10px; background:var(--panel2); border:1px solid var(--border); color:var(--text); border-radius:7px; padding:6px 8px; font-size:12px; font-family:'IBM Plex Sans',sans-serif; }
        .rw-narratorcard{ border-color:var(--teal); }
        .rw-narrator-sub{ color:var(--muted); font-weight:400; font-size:11px; text-transform:none; letter-spacing:0; }
        .rw-cardel{ background:none; border:none; color:var(--muted); font-size:11px; margin-top:6px; padding:2px 0; }
        .rw-cardel:hover{ color:#e08a8a; }

        /* ---------- Story board (4-row beat structure) ---------- */
        .rw-boardwrap-outer{ width:100%; max-width:100%; }
        .rw-board-toolbar{ display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-bottom:16px; }
        .rw-board-hint{ font-family:'IBM Plex Sans',sans-serif; font-size:11px; color:var(--muted); line-height:1.5; }

        .rw-actrows{ display:flex; flex-direction:column; gap:16px; }
        .rw-actrow{ background:var(--panel); border:1px solid var(--border); border-radius:12px; }
        .rw-actrow-header{ display:flex; align-items:center; gap:10px; padding:12px 14px; border-bottom:1px solid var(--border); }
        .rw-actrow-title{ font-weight:700; font-size:14px; }
        .rw-actrow-sub{ color:var(--muted); font-size:11px; text-transform:uppercase; letter-spacing:.06em; flex:1; }
        .rw-actcol-add{ background:var(--panel2); border:1px solid var(--border); color:var(--text); border-radius:7px; padding:6px 10px; font-size:11.5px; font-weight:600; }
        .rw-actcol-add:hover{ border-color:var(--amber); color:var(--amber-soft); }
        .rw-actrow-track{ display:flex; gap:12px; overflow-x:auto; padding:14px; align-items:flex-start; min-height:80px; }
        .rw-actrow-track.rw-drop-end{ background:rgba(201,138,62,.08); }
        .rw-actrow-endzone{ flex:0 0 40px; align-self:stretch; }

        .rw-unit{ display:flex; flex-direction:column; gap:4px; flex:0 0 220px; transition:opacity .15s; }
        .rw-unit.rw-dragging-source{ opacity:.35; }
        .rw-unit.rw-hover-before{ box-shadow:-3px 0 0 var(--amber); }
        .rw-unit.rw-hover-after{ box-shadow:3px 0 0 var(--amber); }
        .rw-unit.rw-hover-stack{ outline:2px dashed var(--amber); outline-offset:3px; border-radius:10px; }
        .rw-unit-move{ display:flex; gap:4px; align-items:center; }
        .rw-unit-move button{ background:none; border:none; color:var(--muted); font-size:10px; padding:2px 4px; flex:1; }
        .rw-unit-move button:hover{ color:var(--amber-soft); }
        .rw-actselect{ background:var(--panel2); border:1px solid var(--border); color:var(--muted); border-radius:5px; font-size:9.5px; padding:2px 3px; }

        .rw-draghandle{ cursor:grab; color:var(--muted); font-size:14px; padding:2px 6px 2px 0; touch-action:none; user-select:none; }
        .rw-draghandle:hover{ color:var(--amber-soft); }
        .rw-dragghost{ position:fixed; z-index:80; pointer-events:none; background:var(--panel2); border:2px solid var(--amber); border-radius:8px; padding:8px 12px; font-family:'IBM Plex Sans',sans-serif; font-size:12px; color:var(--text); box-shadow:0 12px 30px rgba(0,0,0,.5); opacity:.95; }

        .rw-beatbadge{ font-family:'IBM Plex Sans',sans-serif; font-size:9.5px; font-weight:700; letter-spacing:.05em; text-transform:uppercase; color:#C98A3E; }
        .rw-beatbadge span{ font-weight:400; text-transform:none; color:var(--muted); letter-spacing:0; }
        .rw-scenebadge{ font-family:'IBM Plex Sans',sans-serif; font-size:9.5px; font-weight:700; letter-spacing:.06em; color:var(--teal); }

        .rw-scene-setting{ background:var(--panel); border:1px solid var(--border); border-radius:6px; padding:6px 8px; color:var(--amber-soft); font-weight:700; font-size:11.5px; font-family:'Courier Prime',monospace; letter-spacing:.02em; outline:none; }
        .rw-scene-setting:focus{ border-color:var(--amber); }
        .rw-scene-label{ font-family:'IBM Plex Sans',sans-serif; font-size:9px; text-transform:uppercase; letter-spacing:.06em; color:var(--muted); margin-top:2px; }
        .rw-scene-details{ min-height:40px; opacity:.85; }
        .rw-scene-conflict{ background:var(--panel); border:1px solid var(--border); border-radius:6px; padding:6px 8px; color:var(--text); font-size:12px; font-family:'IBM Plex Sans',sans-serif; outline:none; }
        .rw-scene-conflict:focus{ border-color:var(--amber); }

        .rw-tagsuggest-chip{ background:var(--panel); border:1px dashed var(--border); color:var(--muted); border-radius:20px; padding:2px 9px; font-size:10px; font-family:'IBM Plex Sans',sans-serif; }
        .rw-tagsuggest-chip:hover{ border-style:solid; border-color:var(--amber); color:var(--amber-soft); }
        .rw-tagsuggest-chip.rw-tag-character{ border-color:rgba(201,138,62,.4); }

        .rw-storycard{ background:var(--panel2); border:1px solid var(--border); border-top:4px solid var(--amber); border-radius:10px; padding:12px; display:flex; flex-direction:column; gap:6px; }
        .rw-storycard-top{ display:flex; align-items:center; gap:6px; }
        .rw-storycard-title{ background:transparent; border:none; color:var(--text); font-weight:600; font-size:13px; outline:none; font-family:'IBM Plex Sans',sans-serif; }
        .rw-storycard-body{ background:transparent; border:none; color:var(--muted); font-family:'IBM Plex Sans',sans-serif; font-size:12px; line-height:1.5; outline:none; resize:vertical; min-height:56px; }
        .rw-storycard-actions{ display:flex; gap:6px; justify-content:space-between; align-items:center; }
        .rw-storycard-actions button{ background:var(--panel); border:1px solid var(--border); color:var(--text); border-radius:6px; padding:4px 8px; font-size:10.5px; }
        .rw-storycard-actions .rw-cardel{ background:none; border:none; }

        .rw-tagrow{ display:flex; flex-wrap:wrap; gap:5px; align-items:center; }
        .rw-tagchip{ display:inline-flex; align-items:center; gap:4px; background:var(--panel); border:1px solid var(--border); color:var(--muted); border-radius:20px; padding:2px 4px 2px 9px; font-size:10.5px; font-family:'IBM Plex Sans',sans-serif; }
        .rw-tagchip button{ background:none; border:none; color:var(--muted); font-size:12px; padding:0 5px; line-height:1; }
        .rw-tagchip button:hover{ color:#e08a8a; }
        .rw-tagchip.rw-tag-character{ border-color:rgba(201,138,62,.5); color:var(--amber-soft); }
        .rw-tagadd{ background:none; border:1px dashed var(--border); color:var(--muted); border-radius:20px; padding:2px 9px; font-size:10.5px; }
        .rw-tagadd:hover{ border-color:var(--amber); color:var(--amber-soft); }
        .rw-tag-input{ background:var(--panel); border:1px solid var(--amber); border-radius:20px; padding:2px 9px; font-size:10.5px; color:var(--text); width:110px; font-family:'IBM Plex Sans',sans-serif; }

        .rw-tagfilter{ display:flex; flex-wrap:wrap; align-items:center; gap:6px; margin:-6px 0 16px; }
        .rw-tagfilter-label{ font-family:'IBM Plex Sans',sans-serif; font-size:11px; color:var(--muted); margin-right:2px; }
        .rw-tagchip-filter{ cursor:pointer; padding:4px 12px; }
        .rw-tagchip-filter.active{ background:var(--amber); color:#1a1305; border-color:var(--amber); font-weight:600; }
        .rw-tagchip-filter.active.rw-tag-character{ color:#1a1305; }
        .rw-stackselect{ background:var(--panel); border:1px solid var(--border); color:var(--muted); border-radius:6px; font-size:10.5px; padding:4px 6px; max-width:130px; }

        .rw-stackpreview{ position:relative; background:var(--panel2); border:1px solid var(--border); border-top:4px solid; border-radius:10px; padding:14px 12px 10px; display:flex; gap:6px; align-items:flex-start; }
        .rw-stackpreview > div:last-child{ cursor:pointer; flex:1; }
        .rw-stack-shadow{ position:absolute; inset:0; border-radius:10px; background:var(--panel2); border:1px solid var(--border); z-index:-1; }
        .rw-stack-shadow.s1{ transform:translate(4px,4px); }
        .rw-stack-shadow.s2{ transform:translate(8px,8px); }
        .rw-stackcount{ font-family:'IBM Plex Sans',sans-serif; font-size:10px; color:var(--amber-soft); font-weight:600; margin-bottom:4px; }
        .rw-storycard-title-static{ font-size:13px; font-weight:600; color:var(--text); }
        .rw-stack-collapsebar{ width:100%; background:var(--panel2); border:1px dashed var(--border); color:var(--muted); border-radius:8px; padding:6px; font-size:10.5px; }

        .rw-quickcapture-acts{ display:flex; gap:6px; margin-bottom:10px; }
        .rw-qc-actbtn{ flex:1; background:var(--panel2); border:1px solid var(--border); color:var(--muted); border-radius:7px; padding:7px; font-size:12px; font-weight:600; }
        .rw-qc-actbtn.active{ background:var(--amber); color:#1a1305; border-color:var(--amber); }

        /* ---------- Quick capture ---------- */
        .rw-fab{ position:fixed; right:22px; bottom:28px; width:56px; height:56px; border-radius:50%; background:var(--amber); color:#1a1305; border:none; font-size:28px; line-height:1; box-shadow:0 8px 24px rgba(0,0,0,.4); z-index:50; }

        .rw-readbar{ position:fixed; left:0; right:0; bottom:0; background:var(--panel); border-top:1px solid var(--border); padding:10px 16px 14px; z-index:55; box-shadow:0 -8px 24px rgba(0,0,0,.4); }
        .rw-readbar-row{ display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-top:6px; }
        .rw-readbar-row:first-child{ margin-top:0; }
        .rw-readbtn{ background:var(--panel2); border:1px solid var(--border); color:var(--text); border-radius:8px; padding:7px 12px; font-size:12.5px; font-weight:600; }
        .rw-readbtn:hover{ border-color:var(--teal); color:var(--teal); }
        .rw-readbtn:disabled{ opacity:.4; }
        .rw-readbtn-primary{ background:var(--teal); color:#0e2126; border-color:var(--teal); }
        .rw-readbar-label{ font-family:'IBM Plex Sans',sans-serif; font-size:11.5px; color:var(--muted); white-space:nowrap; }
        .rw-readbar-status{ font-family:'IBM Plex Sans',sans-serif; font-size:11.5px; color:var(--muted); margin-left:auto; }
        .rw-fab:active{ transform:scale(0.94); }
        .rw-quickcapture-scrim{ position:fixed; inset:0; background:rgba(0,0,0,.55); z-index:60; display:flex; align-items:flex-end; justify-content:center; }
        @media (min-width:700px){ .rw-quickcapture-scrim{ align-items:center; } }
        .rw-quickcapture{ background:var(--panel); border:1px solid var(--border); border-radius:16px 16px 0 0; padding:18px; width:100%; max-width:520px; }
        @media (min-width:700px){ .rw-quickcapture{ border-radius:16px; } }
        .rw-quickcapture-label{ font-family:'IBM Plex Sans',sans-serif; font-size:11.5px; color:var(--muted); margin-bottom:10px; }
        .rw-quickcapture-input{ width:100%; min-height:110px; background:var(--panel2); border:1px solid var(--border); border-radius:10px; padding:12px; color:var(--text); font-family:'IBM Plex Sans',sans-serif; font-size:14px; line-height:1.5; outline:none; resize:vertical; }
        .rw-quickcapture-input:focus{ border-color:var(--amber); }
        .rw-quickcapture-actions{ display:flex; justify-content:flex-end; gap:8px; margin-top:12px; }
        .rw-quicksave{ background:var(--amber); color:#1a1305; border:none; border-radius:8px; padding:9px 16px; font-weight:600; font-size:13px; }

        /* ---------- Title page ---------- */
        .rw-tp{ height:9in; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; gap:6px; }
        .rw-tp input{ font-family:'Courier Prime',monospace; text-align:center; border:none; background:transparent; outline:none; color:#111; }
        .rw-tp .tp-title{ font-size:16pt; font-weight:700; text-transform:uppercase; width:100%; }
        .rw-tp .tp-by{ font-size:12pt; margin-top:10pt; }
        .rw-tp .tp-author{ font-size:12pt; width:100%; }
        .rw-tp-bottom{ position:absolute; bottom:1in; left:1.5in; right:1in; display:flex; justify-content:space-between; font-size:10pt; }
        .rw-tp-wrap{ position:relative; height:9in; }
        .rw-tp-bottom input{ text-align:left; width:2.4in; }
        .rw-tp-bottom input:last-child{ text-align:right; }

        /* ---------- Bottom status bar ---------- */
        .rw-statusbar{ display:flex; align-items:center; justify-content:center; gap:18px; padding:9px 16px; border-top:1px solid var(--border); background:var(--panel); font-family:'IBM Plex Sans',sans-serif; font-size:12px; color:var(--muted); flex-wrap:wrap; text-align:center; }
        .rw-statusbar strong{ color:var(--text); }
        .rw-statusbar .rw-savepill{ display:flex; align-items:center; gap:5px; }
        .rw-savedot{ width:6px; height:6px; border-radius:50%; background:#5fbf76; }
        .rw-savedot.saving{ background:var(--amber); }
        .rw-hint{ display:none; }
        @media (min-width: 700px){ .rw-hint{ display:inline; } }

        /* ---------- Mobile ---------- */
        .rw-scrim{ display:none; }
        .rw-typebar-kb{ display:none; }
        @media (max-width: 980px){
          .rw-sidebar{ position:fixed; z-index:40; left:0; top:0; transform:translateX(-100%); transition:transform .2s ease; box-shadow:20px 0 40px rgba(0,0,0,.4); }
          .rw-sidebar.open{ transform:translateX(0); }
          .rw-navpanel{ position:fixed; z-index:40; right:0; top:0; transform:translateX(100%); transition:transform .2s ease; box-shadow:-20px 0 40px rgba(0,0,0,.4); }
          .rw-navpanel.open{ transform:translateX(0); }
          .rw-hamb{ display:block; }
          .rw-scrim.open{ display:block; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:38; }
          .rw-page{ padding:.6in .5in .6in .8in; font-size:11pt; }
          .sp-character{ margin-left:1in; }
          .sp-parenthetical{ margin-left:.7in; max-width:2.6in; }
          .sp-dialogue{ margin-left:.4in; max-width:100%; }
          .rw-pagebadge{ right:.5in; }
          .rw-unit{ flex-basis:78vw; }
          .rw-typebar-kb{ display:flex; align-items:center; gap:6px; position:fixed; left:0; right:0; bottom:0; background:var(--panel); border-top:1px solid var(--border); padding:8px 10px; z-index:75; box-shadow:0 -6px 16px rgba(0,0,0,.4); overflow-x:auto; -webkit-overflow-scrolling:touch; will-change:transform; }
          .rw-typebar-kb > button:first-child, .rw-typebar-kb > button:last-child{ flex-shrink:0; background:var(--panel2); border:1px solid var(--border); color:var(--amber-soft); width:38px; height:38px; border-radius:19px; font-size:18px; line-height:1; }
          .rw-typebar-kb-pill{ flex-shrink:0; background:var(--panel2); border:1px solid var(--border); color:var(--muted); border-radius:20px; padding:9px 14px; font-size:12.5px; font-weight:600; white-space:nowrap; }
          .rw-typebar-kb-pill.active{ background:var(--amber); color:#1a1305; border-color:var(--amber); }
        }

        /* ---------- Print ---------- */
        @media print{
          body *{ visibility:hidden; }
          .rw-canvas, .rw-canvas *{ visibility:visible; }
          .rw-importbanner, .rw-chiprow{ display:none; }
          .rw-page{ box-shadow:none; margin:0 !important; width:8.5in; min-height:11in; padding:1in 1in 1in 1.5in; break-after:page; }
          .rw-page:last-child{ break-after:auto; }
          @page{ size: letter; margin:0; }
          .sp-block:empty::before{ content:''; }
        }
